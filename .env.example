# ============================================================
# Variabili d'ambiente - copia in .env e compila i valori
# ============================================================

# Connessione PostgreSQL (es. Railway, Render, Supabase, Neon, Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:5432/daytracker?schema=public"

# Segreto per firmare le sessioni JWT di NextAuth.
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="genera-una-stringa-casuale-lunga"

# URL base dell'app (in produzione es. https://tuoapp.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# Credenziali per il seed iniziale (un solo utente, te stesso)
SEED_EMAIL="tu@esempio.com"
SEED_PASSWORD="una-password-sicura"
